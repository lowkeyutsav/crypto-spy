{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env --allow-read --env src/index.ts",
    "migration:run": "deno run -A npm:drizzle-kit migrate",
    "migration:generate": "deno run -A npm:drizzle-kit generate",
    "db:push": "deno run -A npm:drizzle-kit push"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@types/pg": "npm:@types/pg@^8.20.0",
    "bcrypt": "npm:bcrypt@^6.0.0",
    "bcryptjs": "npm:bcryptjs@^3.0.3",
    "better-auth": "npm:better-auth@^1.6.23",
    "dotenv": "npm:dotenv@^17.4.2",
    "drizzle-kit": "npm:drizzle-kit@^0.31.10",
    "drizzle-orm": "npm:drizzle-orm@^0.45.2",
    "hono": "npm:hono@^4.12.27",
    "nodemailer": "npm:nodemailer@^9.0.3",
    "pg": "npm:pg@^8.22.0"
  }
}
